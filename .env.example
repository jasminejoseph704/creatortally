# Creator Tally Environment Variables
# Copy this file to .env for local development
# IMPORTANT: Never commit .env to version control!

# ===========================================
# SUPABASE (Database + Authentication)
# ===========================================
# 1. Create account at https://supabase.com
# 2. Create new project
# 3. Go to Settings > API
# 4. Copy "Project URL" and "anon/public" keys

SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6I
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6I

# ===========================================
# STRIPE (Payment Processing)
# ===========================================
# 1. Create account at https://stripe.com
# 2. Get API keys: Dashboard > Developers > API keys
#    - Publishable key (pk_live_...) goes to frontend
#    - Secret key (sk_live_...) goes to backend only

STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# 3. Create product: Dashboard > Products > Add Product
#    - Name: "Creator Tally Pro"
#    - Price: $9/month (recurring)
#    - Copy the Price ID

STRIPE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx

# ===========================================
# APPLICATION
# ===========================================

# Your app's URL (for redirects, webhooks)
URL=https://creatortally.app

# ===========================================
# DEVELOPMENT NOTES
# ===========================================
#
# To run locally with Supabase:
# 1. npm install -g supabase
# 2. supabase login
# 3. supabase link --project-ref xxxxx
# 4. supabase env > .env.local (pulls from remote)
#
# To run Stripe locally:
# 1. npm install stripe
# 2. Use test keys (pk_test_, sk_test_) for development
# 3. Use https://stripe.com/docs/stripe-cli for webhooks
#
# Netlify deployment:
# Add these as Environment Variables in Netlify dashboard
# Site Settings > Environment Variables